rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /venues/{venueId} {
      allow read: if true;
      allow write: if false;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.resource.data.quantityTotal is int
                    && request.resource.data.quantityTotal > 0
                    && request.resource.data.quantityRemaining == request.resource.data.quantityTotal
                    && request.resource.data.editTokenHash is string
                    && request.resource.data.editTokenHash.size() > 0;
      allow update: if request.resource.data.editTokenHash == resource.data.editTokenHash;
    }

    match /reservations/{reservationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.claimerUid;
      allow create: if isSignedIn()
                    && request.resource.data.claimerUid == request.auth.uid
                    && request.resource.data.qty is int
                    && request.resource.data.qty > 0;
      allow update: if isSignedIn() && request.auth.uid == resource.data.claimerUid;
    }

    match /abuse_signals/{signalId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
