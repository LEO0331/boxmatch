    {
      "name": "Enterprise - Create listing",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('create returns listingId + token', function () {",
              "  pm.expect(json.ok).to.eql(true);",
              "  pm.expect(json.listingId).to.be.a('string').and.not.empty;",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('listingId', json.listingId);",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "content-type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": {\n    \"venueId\": \"{{venueId}}\",\n    \"pickupPointText\": \"Postman Booth A\",\n    \"itemType\": \"Lunchbox\",\n    \"description\": \"Postman flow listing\",\n    \"quantityTotal\": 3,\n    \"pickupStartAt\": \"{{pickupStartAt}}\",\n    \"pickupEndAt\": \"{{pickupEndAt}}\",\n    \"expiresAt\": \"{{expiresAt}}\",\n    \"displayNameOptional\": \"Postman Enterprise\",\n    \"visibility\": \"minimal\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/enterprise/listings/create",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "enterprise",
            "listings",
            "create"
          ]
        }
      },
      "response": []
    },
