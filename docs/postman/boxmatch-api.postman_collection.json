{
  "info": {
    "name": "Boxmatch API",
    "_postman_id": "c7d6cf6f-9ef6-4a4a-bcc4-2ab7d5f7d105",
    "description": "Boxmatch backend API test collection. Includes enterprise + recipient full flow with variable chaining.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = new Date();",
          "const start = new Date(now.getTime() + 20 * 60 * 1000);",
          "const end = new Date(now.getTime() + 110 * 60 * 1000);",
          "const expire = new Date(now.getTime() + 150 * 60 * 1000);",
          "pm.collectionVariables.set('pickupStartAt', start.toISOString());",
          "pm.collectionVariables.set('pickupEndAt', end.toISOString());",
          "pm.collectionVariables.set('expiresAt', expire.toISOString());",
          "if (!pm.collectionVariables.get('claimerUid')) {",
          "  pm.collectionVariables.set('claimerUid', `postman_${Date.now()}`);",
          "}",
          "if (!pm.collectionVariables.get('idempotencyKey')) {",
          "  pm.collectionVariables.set('idempotencyKey', `reserve_${Date.now()}`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
